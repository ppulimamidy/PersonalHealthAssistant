# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
venv-*/
ENV/
env/
.venv/

# ── Node / npm / yarn / pnpm ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# Lock files excluded — mobile package-lock exceeds pre-commit 500 KB limit
apps/mobile/package-lock.json

# ── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
.turbo/

# Frontend uses `src/lib/` for shared modules (do not ignore)
!frontend/src/lib/
!frontend/src/lib/**

# ── Expo / React Native ──────────────────────────────────────────────────────
.expo/
.expo-shared/
# Android generated
android/build/
android/.gradle/
android/app/build/
android/app/release/
*.apk
*.aab
# iOS generated (Pods and build/ handled by apps/mobile/ios/.gitignore)
*.ipa
*.dSYM.zip
*.dSYM

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.*
.env.local
.env.*.local
*.env
!*.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
traefik/logs/

